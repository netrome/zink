{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "zink",
  "version": "0.1.0",
  "identifier": "se.blankfors.zink",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "sh -c 'sh \"$(git rev-parse --show-toplevel)/app/ui/build.sh\"'",
    "beforeBuildCommand": "sh -c 'sh \"$(git rev-parse --show-toplevel)/app/ui/build.sh\"'"
  },
  "app": {
    "windows": [
      {
        "title": "zink",
        "width": 420,
        "height": 720
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
