{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "zink",
  "version": "0.1.0",
  "identifier": "org.nearone.zink",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "zink",
        "width": 420,
        "height": 720
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
